# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5) + Okta
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored — never commit real secrets.
# ---------------------------------------------------------------------------

# Random secret used to encrypt the session JWT.
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# From your Okta application (Admin Console > Applications > your app).
AUTH_OKTA_ID=
AUTH_OKTA_SECRET=

# Your Okta issuer URL, e.g. https://dev-1234567.okta.com/oauth2/default
# Found under Security > API > Authorization Servers (the "Issuer URI").
AUTH_OKTA_ISSUER=
